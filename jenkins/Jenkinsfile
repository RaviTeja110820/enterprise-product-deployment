pipeline {
    agent any

    environment {

        // AWS
        AWS_REGION      = 'ap-south-2'
        AWS_ACCOUNT_ID  = '705557196379'
        ECR_REPOSITORY  = 'enterprise-app'

        // EKS
        CLUSTER_NAME    = 'enterprise-product-eks'
        NAMESPACE       = 'enterprise'
        DEPLOYMENT_NAME = 'enterprise-app'
        CONTAINER_NAME  = 'enterprise-app'

        // Secrets Manager
        SECRET_NAME     = 'enterprise-app-secret'

        // Docker
        IMAGE_TAG = "v${BUILD_NUMBER}"
        IMAGE_URI = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPOSITORY}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Application') {
            steps {
                dir('app') {
                    sh 'mvn clean package'
                }
            }
        }

        stage('Run Unit Tests') {
            steps {
                dir('app') {
                    sh 'mvn test'
                }
            }
        }

        stage('SonarCloud Analysis') {
            steps {
                dir('app') {
                    withSonarQubeEnv('SonarCloud') {
                        withCredentials([
                            string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')
                        ]) {
                            sh '''
                            mvn sonar:sonar \
                            -Dsonar.projectKey=RaviTeja110820_enterprise-product-deployment \
                            -Dsonar.organization=mysonarpro \
                            -Dsonar.host.url=https://sonarcloud.io \
                            -Dsonar.token=$SONAR_TOKEN
                            '''
                        }
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('app') {
                    sh """
                    docker build \
                    -t ${ECR_REPOSITORY}:${IMAGE_TAG} .
                    """
                }
            }
        }

        stage('Trivy Security Scan') {
            steps {
                sh """
                trivy image \
                --severity HIGH,CRITICAL \
                --no-progress \
                ${ECR_REPOSITORY}:${IMAGE_TAG}
                """
            }
        }

        /*
        For demonstration of pipeline failure:

        trivy image \
        --severity HIGH,CRITICAL \
        --exit-code 1 \
        --no-progress \
        ${ECR_REPOSITORY}:${IMAGE_TAG}
        */

        stage('Login to Amazon ECR') {
            steps {
                sh """
                aws ecr get-login-password \
                --region ${AWS_REGION} | \
                docker login \
                --username AWS \
                --password-stdin ${IMAGE_URI}
                """
            }
        }

        stage('Push Docker Image') {
            steps {
                sh """
                docker tag ${ECR_REPOSITORY}:${IMAGE_TAG} ${IMAGE_URI}:${IMAGE_TAG}
                docker push ${IMAGE_URI}:${IMAGE_TAG}
                """
            }
        }

        stage('Update kubeconfig') {
            steps {
                sh """
                aws eks update-kubeconfig \
                --region ${AWS_REGION} \
                --name ${CLUSTER_NAME}
                """
            }
        }

        stage('Inject Secret from AWS Secrets Manager') {
            steps {
                sh '''
                SECRET=$(aws secretsmanager get-secret-value \
                --secret-id $SECRET_NAME \
                --region $AWS_REGION \
                --query SecretString \
                --output text)

                APP_SECRET=$(echo $SECRET | jq -r '.APP_SECRET')

                kubectl delete secret enterprise-secret \
                -n $NAMESPACE \
                --ignore-not-found

                kubectl create secret generic enterprise-secret \
                --from-literal=APP_SECRET="$APP_SECRET" \
                -n $NAMESPACE
                '''
            }
        }

        stage('Deploy to Amazon EKS') {
            steps {
                sh """
                kubectl set image deployment/${DEPLOYMENT_NAME} \
                ${CONTAINER_NAME}=${IMAGE_URI}:${IMAGE_TAG} \
                -n ${NAMESPACE}
                """
            }
        }

        stage('Verify Rollout') {
            steps {
                sh """
                kubectl rollout status deployment/${DEPLOYMENT_NAME} \
                -n ${NAMESPACE}
                """
            }
        }

        stage('Verify Deployment') {
            steps {
                sh """
                echo "================ Pods ================"
                kubectl get pods -n ${NAMESPACE}

                echo ""
                echo "============== Services =============="
                kubectl get svc -n ${NAMESPACE}

                echo ""
                echo "============= Deployment ============="
                kubectl get deployment -n ${NAMESPACE}

                echo ""
                echo "=============== Secret ==============="
                kubectl get secret enterprise-secret -n ${NAMESPACE}

                echo ""
                echo "============= Secret Info ============"
                kubectl describe secret enterprise-secret -n ${NAMESPACE}
                """
            }
        }
    }

    post {

        success {
            echo "========================================="
            echo "BUILD SUCCESSFUL"
            echo "========================================="
            echo "Docker Image : ${IMAGE_URI}:${IMAGE_TAG}"
            echo "SonarCloud Analysis : SUCCESS"
            echo "Trivy Scan : COMPLETED"
            echo "AWS Secrets Manager : SUCCESS"
            echo "Application deployed successfully to Amazon EKS"
            echo "========================================="
        }

        failure {
            echo "========================================="
            echo "BUILD FAILED"
            echo "========================================="
        }

        always {
            sh """
            docker image rm -f ${ECR_REPOSITORY}:${IMAGE_TAG} || true
            docker image rm -f ${IMAGE_URI}:${IMAGE_TAG} || true
            docker image prune -f || true
            """

            cleanWs()
        }
    }
}